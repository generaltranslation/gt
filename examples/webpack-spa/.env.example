# Copy this file to .env.local and fill in your credentials to enable
# dev-mode translation hot reload. Both values are optional: without them the
# app still runs and switches between the languages that have files in src/_gt.
#
# Get these by running `npx gt auth` or from https://dash.generaltranslation.com
# Use a development key that starts with gtx-dev-. Never put a production key
# (gtx-api-) in a client-side app.

GT_PROJECT_ID=""
GT_DEV_API_KEY=""
