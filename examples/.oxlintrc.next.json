{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "react",
    "jsx-a11y",
    "nextjs"
  ],
  "ignorePatterns": [".next/**", "out/**", "build/**"],
  "env": {
    "browser": true,
    "builtin": true,
    "node": true
  }
}
