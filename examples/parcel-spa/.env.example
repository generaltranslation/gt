# Copy this file to .env.local and fill in your credentials to enable
# development translations (live machine translation while you edit).
#
# Leave these empty to run the example purely from the local translation
# fixtures in src/_gt/ (no API access required).
#
# Get a development API key at https://dash.generaltranslation.com
# Use a key that starts with gtx-dev- . Never put a production key (gtx-api-)
# in browser code.

GT_PROJECT_ID=""
GT_DEV_API_KEY=""
