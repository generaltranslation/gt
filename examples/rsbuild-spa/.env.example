# Development credentials for GT translation hot reload.
# Rsbuild exposes variables prefixed with PUBLIC_ to client code via
# import.meta.env. Copy this file to .env.local and fill in your values.
#
# Get a development key (starts with gtx-dev-) at
# https://dash.generaltranslation.com. Never use a production key
# (gtx-api-) in browser code, and never commit real values.
#
# These are only needed for `pnpm dev` hot reload. Production builds serve
# the committed files in src/_gt/ and need no credentials.
PUBLIC_GT_PROJECT_ID=""
PUBLIC_GT_DEV_API_KEY=""
