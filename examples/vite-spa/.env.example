# Copy this file to .env.local and fill in your credentials.
# Get them at https://dash.generaltranslation.com/signup or by running `npx gt auth`.
# Use a development key that starts with `gtx-dev-`. Never expose a
# production key (`gtx-api-`) in browser code.
VITE_GT_PROJECT_ID=
VITE_GT_DEV_API_KEY=
