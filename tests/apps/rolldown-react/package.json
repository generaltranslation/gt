{
  "name": "gt-test-rolldown-react",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n rolldown,sirv \"rolldown -c --watch\" \"sirv dist --host 127.0.0.1 --port 5177 --single\"",
