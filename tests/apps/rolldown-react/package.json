    "preview": "sirv dist --host 127.0.0.1 --port 4177 --single",
    "lint": "oxlint --config ../../../examples/.oxlintrc.react.json .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "gt-react": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
