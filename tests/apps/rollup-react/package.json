{
  "name": "gt-test-rollup-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n rollup,sirv \"rollup -c -w\" \"sirv dist --host 127.0.0.1 --port 5176 --single\"",
    "build": "rollup -c",
    "preview": "sirv dist --host 127.0.0.1 --port 4176 --single",
    "lint": "oxlint --config ../../../examples/.oxlintrc.react.json .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "gt-react": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@generaltranslation/compiler": "workspace:*",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "rollup": "^4.62.2",
    "rollup-plugin-postcss": "^4.0.2",
    "sirv-cli": "^3.0.1",
    "tslib": "^2.8.1",
    "typescript": "^5"
  }
}
