{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "Preserve",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"]
  },
  "include": ["src/**/*", "src/.ts"],
  "exclude": ["**/__tests__/**/*", "**/__mocks__/**/*"],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../react"
    },
    {
      "path": "../i18n"
    }
  ]
}
