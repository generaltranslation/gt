{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "declarationMap": true,
    "inlineSources": true,

    // Set `sourceRoot` to  "/" to strip the build path prefix
    // from generated source code references.
    // This improves issue grouping in Sentry.
    "sourceRoot": "/",

    "types": ["node"]
  },
  "include": ["src/**/*", "src/.ts"],
  "exclude": ["**/*.test.ts"],
  "references": [
    {
      "path": "../cli"
    }
  ]
}
