{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES6",
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "Bundler",
    "sourceMap": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "composite": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.test.ts"],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../supported-locales"
    },
    {
      "path": "../react"
    },
    {
      "path": "../i18n"
    },
    {
      "path": "../react-core"
    }
  ]
}
