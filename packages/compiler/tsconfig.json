{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "Preserve",
    "target": "ES6",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["**/__tests__/**/*", "../../tests/seeds"],
  "references": [
    {
      "path": "../core"
    }
  ]
}
