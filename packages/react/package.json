{
  "name": "gt-react",
  "version": "10.19.3",
  "description": "A React library for automatic internationalization.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "dependencies": {
    "@generaltranslation/supported-locales": "workspace:*",
    "generaltranslation": "workspace:*",
    "@generaltranslation/react-core": "workspace:*",
    "gt-i18n": "workspace:*"
  },
  "scripts": {
    "patch": "pnpm version patch",
    "transpile": "tsc",
    "build": "tsdown",
    "build:clean": "sh ../../scripts/clean.sh && pnpm run build",
    "build:release": "pnpm run build:clean",
    "release": "pnpm run build:clean && pnpm publish",
    "release:alpha": "pnpm run build:clean && pnpm publish --tag alpha",
    "release:beta": "pnpm run build:clean && pnpm publish --tag beta",
    "release:latest": "pnpm run build:clean && pnpm publish --tag latest",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\" \"__tests__/**/*.{js,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,ts,tsx}\" \"__tests__/**/*.{js,ts,tsx}\" --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/generaltranslation/gt.git"
  },
  "author": "General Translation, Inc.",
  "license": "FSL-1.1-ALv2",
  "bugs": {
    "url": "https://github.com/generaltranslation/gt/issues"
  },
  "homepage": "https://generaltranslation.com/",
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": ">=18.0.0 <20.0.0",
    "@types/react-dom": ">=18.0.0 <20.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.7.3"
  },
  "typescript": {
    "definition": "dist/index.d.cts"
  },
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./internal": {
      "require": {
        "types": "./dist/internal.d.cts",
        "default": "./dist/internal.cjs"
      },
      "import": {
        "types": "./dist/internal.d.mts",
        "default": "./dist/internal.mjs"
      }
    },
    "./client": {
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      },
      "import": {
        "types": "./dist/client.d.mts",
        "default": "./dist/client.mjs"
      }
    },
    "./browser": {
      "require": {
        "types": "./dist/browser.d.cts",
        "default": "./dist/browser.cjs"
      },
      "import": {
        "types": "./dist/browser.d.mts",
        "default": "./dist/browser.mjs"
      }
    },
    "./browser/types": {
      "require": {
        "types": "./dist/browser-types.d.cts",
        "default": "./dist/browser-types.cjs"
      },
      "import": {
        "types": "./dist/browser-types.d.mts",
        "default": "./dist/browser-types.mjs"
      }
    },
    "./macros": {
      "require": {
        "types": "./dist/macros.d.cts",
        "default": "./dist/macros.cjs"
      },
      "import": {
        "types": "./dist/macros.d.mts",
        "default": "./dist/macros.mjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "./dist/client.d.cts"
      ],
      "internal": [
        "./dist/internal.d.cts"
      ],
      "setup": [
        "./dist/setup.d.cts"
      ],
      "browser": [
        "./dist/browser.d.cts"
      ],
      "browser/types": [
        "./dist/browser-types.d.cts"
      ],
      "macros": [
        "./dist/macros.d.cts"
      ]
    }
  },
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "gt-react/client": [
        "./dist/client"
      ],
      "gt-react/internal": [
        "./dist/internal"
      ],
      "gt-react/setup": [
        "./dist/setup.d.cts"
      ],
      "gt-react/browser": [
        "./dist/browser.d.cts"
      ],
      "gt-react/browser/types": [
        "./dist/browser-types.d.cts"
      ],
      "gt-react/macros": [
        "./dist/macros.d.cts"
      ]
    }
  },
  "keywords": [
    "react",
    "translation",
    "internationalization",
    "localization",
    "i18n"
  ]
}
