{
  "name": "gt-react",
  "version": "10.20.0",
  "description": "A React library for automatic internationalization.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "./dist/browser.*",
    "./dist/macros.*"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@generaltranslation/format": "workspace:*",
    "@generaltranslation/supported-locales": "workspace:*",
    "generaltranslation": "workspace:*",
    "@generaltranslation/react-core": "workspace:*",
    "gt-i18n": "workspace:*"
  },
  "scripts": {
    "patch": "pnpm version patch",
    "transpile": "tsdown",
    "build": "tsdown",
    "build:clean": "sh ../../scripts/clean.sh && pnpm run build",
    "build:release": "pnpm run build:clean",
    "release": "pnpm run build:clean && pnpm publish",
    "release:alpha": "pnpm run build:clean && pnpm publish --tag alpha",
    "release:beta": "pnpm run build:clean && pnpm publish --tag beta",
    "release:latest": "pnpm run build:clean && pnpm publish --tag latest",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/generaltranslation/gt.git"
  },
  "author": "General Translation, Inc.",
  "license": "FSL-1.1-ALv2",
  "bugs": {
    "url": "https://github.com/generaltranslation/gt/issues"
  },
  "homepage": "https://generaltranslation.com/",
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": ">=18.0.0 <20.0.0",
    "@types/react-dom": ">=18.0.0 <20.0.0",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./internal": {
      "require": {
        "types": "./dist/internal.d.cts",
        "default": "./dist/internal.cjs"
      },
      "import": {
        "types": "./dist/internal.d.mts",
        "default": "./dist/internal.mjs"
      }
    },
    "./client": {
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      },
      "import": {
        "types": "./dist/client.d.mts",
        "default": "./dist/client.mjs"
      }
    },
    "./context": {
      "react-server": {
        "require": {
          "types": "./dist/context.types.d.cts",
          "default": "./dist/context.server.cjs"
        },
        "import": {
          "types": "./dist/context.types.d.mts",
          "default": "./dist/context.server.mjs"
        },
        "default": "./dist/context.server.mjs"
      },
      "browser": {
        "require": {
          "types": "./dist/context.types.d.cts",
          "default": "./dist/context.client.cjs"
        },
        "import": {
          "types": "./dist/context.types.d.mts",
          "default": "./dist/context.client.mjs"
        },
        "default": "./dist/context.client.mjs"
      },
      "require": {
        "types": "./dist/context.types.d.cts",
        "default": "./dist/context.server.cjs"
      },
      "import": {
        "types": "./dist/context.types.d.mts",
        "default": "./dist/context.server.mjs"
      },
      "default": "./dist/context.server.mjs"
    },
    "./context-rsc": {
      "react-server": {
        "require": {
          "types": "./dist/context-rsc.d.cts",
          "default": "./dist/context-rsc.cjs"
        },
        "import": {
          "types": "./dist/context-rsc.d.mts",
          "default": "./dist/context-rsc.mjs"
        },
        "default": "./dist/context-rsc.mjs"
      },
      "require": {
        "types": "./dist/context-rsc.d.cts",
        "default": "./dist/context-rsc.cjs"
      },
      "import": {
        "types": "./dist/context-rsc.d.mts",
        "default": "./dist/context-rsc.mjs"
      },
      "default": "./dist/context-rsc.mjs"
    },
    "./internal/locale-selector-client": {
      "require": {
        "types": "./dist/locale-selector.client.d.cts",
        "default": "./dist/locale-selector.client.cjs"
      },
      "import": {
        "types": "./dist/locale-selector.client.d.mts",
        "default": "./dist/locale-selector.client.mjs"
      }
    },
    "./browser": {
      "require": {
        "types": "./dist/browser.d.cts",
        "default": "./dist/browser.cjs"
      },
      "import": {
        "types": "./dist/browser.d.mts",
        "default": "./dist/browser.mjs"
      }
    },
    "./browser/types": {
      "types": "./dist/browser.d.cts"
    },
    "./macros": {
      "require": {
        "types": "./dist/macros.d.cts",
        "default": "./dist/macros.cjs"
      },
      "import": {
        "types": "./dist/macros.d.mts",
        "default": "./dist/macros.mjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "./dist/client.d.cts"
      ],
      "context": [
        "./dist/context.types.d.cts"
      ],
      "context-rsc": [
        "./dist/context-rsc.d.cts"
      ],
      "internal": [
        "./dist/internal.d.cts"
      ],
      "internal/locale-selector-client": [
        "./dist/locale-selector.client.d.cts"
      ],
      "setup": [
        "./dist/setup.d.cts"
      ],
      "browser": [
        "./dist/browser.d.cts"
      ],
      "browser/types": [
        "./dist/browser.d.cts"
      ],
      "macros": [
        "./dist/macros.d.cts"
      ]
    }
  },
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "gt-react/client": [
        "./dist/client"
      ],
      "gt-react/context": [
        "./dist/context.types.d.cts"
      ],
      "gt-react/context-rsc": [
        "./dist/context-rsc.d.cts"
      ],
      "gt-react/internal": [
        "./dist/internal"
      ],
      "gt-react/internal/locale-selector-client": [
        "./dist/locale-selector.client"
      ],
      "gt-react/setup": [
        "./dist/setup.d.cts"
      ],
      "gt-react/browser": [
        "./dist/browser.d.cts"
      ],
      "gt-react/browser/types": [
        "./dist/browser.d.cts"
      ],
      "gt-react/macros": [
        "./dist/macros.d.cts"
      ]
    }
  },
  "keywords": [
    "react",
    "translation",
    "internationalization",
    "localization",
    "i18n"
  ]
}
