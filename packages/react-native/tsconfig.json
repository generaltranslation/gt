{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "sourceMap": false,
    "declarationMap": true,
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "verbatimModuleSyntax": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.test.ts"],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../supported-locales"
    },
    {
      "path": "../react-core"
    }
  ]
}
