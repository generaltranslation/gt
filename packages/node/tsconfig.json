{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "composite": true,
    "stripInternal": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "gt-node": ["./dist/index.d.cts"]
    },
    "lib": ["ES2023"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.test.ts"],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../supported-locales"
    },
    {
      "path": "../i18n"
    }
  ]
}
