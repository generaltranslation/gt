{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "composite": true,
    "stripInternal": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "gt-format": ["dist/index.d.cts"],
      "gt-format/types": ["dist/types.d.cts"]
    },
    "lib": ["ES2023"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
