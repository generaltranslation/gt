{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "composite": true,
    "stripInternal": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@generaltranslation/format": ["./dist/index.d.cts"],
      "@generaltranslation/format/types": ["./dist/types.d.cts"]
    },
    "lib": ["ES2023", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
