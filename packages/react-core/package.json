{
  "name": "@generaltranslation/react-core",
  "version": "11.1.0",
  "description": "A pure React library for internationalization",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@generaltranslation/format": "workspace:*",
    "generaltranslation": "workspace:*",
    "gt-i18n": "workspace:*"
  },
  "scripts": {
    "patch": "pnpm version patch",
    "transpile": "tsdown",
    "build": "tsdown",
    "build:clean": "sh ../../scripts/clean.sh && pnpm run build",
    "build:release": "pnpm run build:clean",
    "release": "pnpm run build:clean && pnpm publish",
    "release:alpha": "pnpm run build:clean && pnpm publish --tag alpha",
    "release:beta": "pnpm run build:clean && pnpm publish --tag beta",
    "release:latest": "pnpm run build:clean && pnpm publish --tag latest",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/generaltranslation/gt.git"
  },
  "author": "General Translation, Inc.",
  "license": "FSL-1.1-ALv2",
  "bugs": {
    "url": "https://github.com/generaltranslation/gt/issues"
  },
  "homepage": "https://generaltranslation.com/",
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": ">=18.0.0 <20.0.0",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    "./pure": {
      "types": "./dist/pure.d.ts",
      "require": "./dist/pure.cjs",
      "import": "./dist/pure.mjs"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "require": "./dist/hooks.cjs",
      "import": "./dist/hooks.mjs"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "require": "./dist/components.cjs",
      "import": "./dist/components.mjs"
    },
    "./components-rsc": {
      "types": "./dist/components-rsc.d.ts",
      "require": "./dist/components-rsc.cjs",
      "import": "./dist/components-rsc.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "pure": [
        "./dist/pure.d.ts"
      ],
      "hooks": [
        "./dist/hooks.d.ts"
      ],
      "components": [
        "./dist/components.d.ts"
      ],
      "components-rsc": [
        "./dist/components-rsc.d.ts"
      ]
    }
  },
  "keywords": [
    "react",
    "translation",
    "internationalization",
    "localization",
    "i18n"
  ]
}
