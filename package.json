{
  "name": "gt-libraries",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*",
    "tests/apps/**/*"
  ],
  "scripts": {
    "build": "turbo run build --filter='./packages/*' --ui tui",
    "watch": "pnpm build:watch",
    "build:watch": "turbo watch build --filter='./packages/*' --ui tui",
    "test": "turbo run test --filter='./packages/*'",
    "lint": "pnpm check:library-defaults && oxlint packages && pnpm --filter './examples/*' --filter './tests/apps/**/*' --if-present run lint && oxfmt --check .",
    "lint:fix": "oxlint packages --fix && pnpm --filter './examples/*' --filter './tests/apps/**/*' --if-present lint --fix && oxfmt .",
    "transpile": "turbo run transpile --filter='./packages/*'",
    "typecheck": "turbo run typecheck --filter='./packages/*' --filter='./examples/*' --filter='./tests/apps/**/*'",
    "release": "changeset publish",
    "release:gt-bin": "pnpm --filter gt run release:bin",
    "release:gtx-cli-bin": "pnpm --filter gtx-cli run release:bin",
    "build:clean": "turbo run build:clean --filter='./packages/*'",
    "build:release": "turbo run build:release --filter='./packages/*'",
    "bench": "turbo run bench",
    "size": "size-limit",
    "check:library-defaults": "node scripts/check-library-defaults.mjs",
    "check:release-versions": "node scripts/check-release-versions.mjs",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "changeset": "changeset",
    "version-packages": "changeset version && oxfmt packages/*/CHANGELOG.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/generaltranslation/gt.git"
  },
  "author": "General Translation, Inc.",
  "license": "FSL-1.1-ALv2",
  "bugs": {
    "url": "https://github.com/generaltranslation/gt/issues"
  },
  "homepage": "https://generaltranslation.com/",
  "keywords": [
    "react",
    "translation",
    "internationalization",
    "localization",
    "i18n",
    "l10n"
  ],
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.9",
    "@babel/core": "catalog:",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^3.2.4",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "postcss": "^8.5.19",
    "size-limit": "^12.1.0",
    "turbo": "^2.5.3",
    "tslib": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.20.0",
  "dependencies": {
    "lefthook": "^1.12.3",
    "vite": "^7.0.5"
  }
}
