{
  "name": "gt-libraries",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*",
    "tests/apps/**/*"
  ],
  "scripts": {
    "build": "turbo run build --filter='./packages/*'",
    "test": "turbo run test --filter='./packages/*'",
    "lint": "oxlint packages && oxfmt --check .",
    "lint:fix": "oxlint packages --fix && oxfmt .",
    "transpile": "turbo run transpile --filter='./packages/*'",
    "release": "changeset publish",
    "release:gt-bin": "pnpm --filter gt run release:bin",
    "release:gtx-cli-bin": "pnpm --filter gtx-cli run release:bin",
    "build:clean": "turbo run build:clean --filter='./packages/*'",
    "build:release": "turbo run build:release --filter='./packages/*'",
    "bench": "turbo run bench",
    "size": "size-limit",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/generaltranslation/gt.git"
  },
  "author": "General Translation, Inc.",
  "license": "FSL-1.1-ALv2",
  "bugs": {
    "url": "https://github.com/generaltranslation/gt/issues"
  },
  "homepage": "https://generaltranslation.com/",
  "keywords": [
    "react",
    "translation",
    "internationalization",
    "localization",
    "i18n",
    "l10n"
  ],
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.27.9",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^3.2.4",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "prettier": "^3.6.2",
    "size-limit": "^12.1.0",
    "turbo": "^2.5.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.20.0",
  "dependencies": {
    "@generaltranslation/next-internal": "link:packages/next-internal",
    "lefthook": "^1.12.3",
    "vite": "^7.0.5"
  }
}
